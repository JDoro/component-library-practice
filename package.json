{
  "name": "component-library-practice",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "release": "standard-version",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npm run build-storybook && npx http-server storybook-static --port 6006 \" \"wait-on tcp:127.0.0.1:6006 && npm run test-storybook\"",
    "test-storybook:coverage": "test-storybook --coverage",
    "coverage-report": "cp coverage/storybook/coverage-storybook.json coverage/coverage-storybook.json && nyc report --reporter=html -t coverage --report-dir coverage"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/jest-image-snapshot": "^6.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^17.4.0",
    "http-server": "^14.1.1",
    "jest-html-reporters": "^3.1.7",
    "jest-image-snapshot": "^6.5.2",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "standard-version": "^9.5.0",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "tw-colors": "^3.3.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "peerDependencies": {
    "storybook": "^10.3.3"
  }
}
